# Build output
dist/

# Dependencies
node_modules/

# Atlas build output — generated by free-tex-packer-core from assets/raw/
# (per proposal section 2). Ignore contents, not the directory itself,
# so the .gitkeep can be re-included — Git won't re-include a path under
# an ignored directory.
assets/atlas/*
!assets/atlas/.gitkeep

# Editor / OS noise
.DS_Store
.idea/
.vscode/
*.swp

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Test artifacts (Playwright)
test-results/
playwright-report/
playwright/.cache/
